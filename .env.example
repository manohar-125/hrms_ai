# ======================
# LLM & Embedding Configuration
# ======================
LLM_PROVIDER=openai
EMBED_MODEL=BAAI/bge-small-en
CHROMA_PATH=./chroma_db

# Provider API Keys (at least one required)
OPENAI_API_KEY=
GROQ_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Provider Model Names (optional, defaults provided)
OPENAI_MODEL=gpt-4o-mini
GROQ_MODEL=llama-3.1-8b-instant
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
GEMINI_MODEL=gemini-2.0-flash
GROQ_BASE_URL=https://api.groq.com/openai/v1

# ======================
# HRMS API Configuration
# ======================
HRMS_API_BASE_URL=https://hrmsapi.leanxpert.in
HRMS_API_TOKEN=

# ======================
# Redis Configuration
# ======================
REDIS_HOST=localhost
REDIS_PORT=6379
ENABLE_CACHE=true
CACHE_TTL=600

# ======================
# API Selection & LLM Prompt Tuning
# ======================
SEMANTIC_SEARCH_K=10
KEYWORD_WEIGHT=0.5
SIMILARITY_THRESHOLD=0.2
REQUIRE_HIGH_CONFIDENCE=true
LLM_MAX_PROMPT_TOKENS=
LLM_MAX_API_ITEMS=50
LLM_MAX_API_RESPONSE_CHARS=12000

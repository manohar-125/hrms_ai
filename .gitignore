# ============================
# HRMS AI Service - .gitignore
# ============================

# ----------------------------
# Python
# ----------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# ----------------------------
# Virtual Environments
# ----------------------------
venv/
env/
ENV/
.venv/
venv.bak/

# ----------------------------
# Environment Variables
# ----------------------------
.env
.env.*
*.env

# ----------------------------
# IDE / Editors
# ----------------------------
.vscode/
.idea/
*.swp
*.swo

# ----------------------------
# OS Files
# ----------------------------
.DS_Store
Thumbs.db

# ----------------------------
# Logs
# ----------------------------
*.log
logs/

# ----------------------------
# Database Files
# ----------------------------
*.sqlite3
*.db

# ----------------------------
# Chroma Vector Database
# ----------------------------
chroma_db/
*.bin
*.parquet

# ----------------------------
# Redis
# ----------------------------
dump.rdb

# ----------------------------
# Docker
# ----------------------------
docker/*.log
docker-compose.override.yml

# ----------------------------
# Python Build / Distribution
# ----------------------------
build/
dist/
*.egg-info/
.eggs/

# ----------------------------
# Testing
# ----------------------------
.coverage
htmlcov/
.pytest_cache/

# ----------------------------
# Cache Files
# ----------------------------
.cache/
.mypy_cache/

# ----------------------------
# Temporary Files
# ----------------------------
*.tmp
*.temp
*.bak

# ----------------------------
# Secrets
# ----------------------------
secrets/
private_keys/
config.local.py

# ----------------------------
# Node (if frontend added later)
# ----------------------------
node_modules/
npm-debug.log
yarn-error.log